  Devis "1" --> "1" StatutDevis : a pour statut
  LigneDevis "1" --> "1" Produit : référence
  LigneDevis "1" --> "0..1" Taxe : applique

  Facture "1" --> "1" User : destinée à
  Facture "1" *-- "1..*" LigneFacture : contient
  Facture "1" *-- "1..*" HistoriqueStatutFacture : historique
  Facture "1" --> "1" StatutFacture : a pour statut
  Facture "1" --> "0..1" ProfilFacturation : personnalisée par
