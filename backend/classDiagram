  Relance "1" --> "1" TypeRelance : de type

  Avoir "0..*" --> "0..1" Avenant : créé depuis
  Avoir "1" --> "1" StatutAvoir : a pour statut
  Avoir "0..*" --> "0..1" Facture : compensé sur

  DocumentExporte "0..*" --> "0..1" Devis : export de
  DocumentExporte "0..*" --> "0..1" Facture : export de
  DocumentExporte "1" --> "1" FormatExport : au format
  ImportDocument "0..1" --> "0..1" Devis : transformé en

  EvenementDomaine "0..*" --> "0..1" Devis : tracé
  EvenementDomaine "0..*" --> "0..1" Facture : tracé
  EvenementDomaine "0..*" --> "0..1" Paiement : tracé
  EvenementDomaine "0..*" --> "0..1" Avoir : tracé

  User "1" --> "1" TypeUser : a pour type
  Devis --> Devise : libellé en
  Facture --> Devise : libellé en